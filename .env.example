# ============================================================================
# Magic Chess Environment Configuration
# ============================================================================
# Copy to .env and fill in values before running server/agents/tests.
# All default values point to Solana devnet + MagicBlock ER devnet.
# ============================================================================

# ─── Solana RPC Endpoints ────────────────────────────────────────────────
# Solana L1 (for creating/delegating game accounts)
RPC_URL=https://api.devnet.solana.com

# MagicBlock Ephemeral Rollup (for sub-100ms make_move transactions)
ER_RPC=https://devnet.magicblock.app


# ─── Deployed Program IDs (devnet) ───────────────────────────────────────
# Chess program — 580 lines of Rust, full chess rules + ER delegation
CHESS_PROGRAM_ID=3LVg8uUsHtq6fusjrSfyGUCLQ83TFegDKmY3bCNz3QYr

# MagicBlock SOAR — on-chain leaderboard + ELO storage
SOAR_PROGRAM_ID=SoarNNzwQHMwcfdkdLc6kvbkoMSxcHy89gTHrjhJYkk


# ─── Server (ER Pool Resolver) ───────────────────────────────────────────
# Resolver URL — used by frontend, agents, and tests
RESOLVER_URL=https://resolver.gamerplex.com

# Authority keypair — server identity that creates + delegates games.
# Provide EITHER a file path OR base64-encoded JSON of the secret key.
# DO NOT commit your actual keypair. Use a file outside the repo.
SOLANA_KEYPAIR=/path/to/your/solana/id.json

# Port for the Express resolver server
PORT=8080


# ─── Agent Configuration ─────────────────────────────────────────────────
# Agent keys directory (created by setup-agents.ts)
AGENT_KEYS_DIR=./keys

# Daemon settings
NUM_GAMES=5             # parallel games to run
MOVE_DELAY_MS=3000      # delay between moves (spectator pacing)
MAX_MOVES=60            # max moves per game before forced draw

# Set CONTINUOUS=true to loop a single match forever
# CONTINUOUS=false

# Optional: pre-pick agent matchup for a single match
# WHITE=sf2400
# BLACK=sf1200
